generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                Int              @id @default(autoincrement())
  name              String
  email             String           @unique
  password          String
  role              Role
  isVerified        Boolean          @default(false)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  bio               String?          @db.Text
  phone             String?
  profileImage      String?
  bankAccounts      BankAccount[]
  charityProfile    CharityProfile?
  donations         Donation[]
  followedCampaigns FollowCampaign[]
}

model CharityProfile {
  id               Int        @id @default(autoincrement())
  userId           Int        @unique
  organizationName String
  description      String     @db.Text
  documentUrl      String
  phone            String?
  address          String?
  website          String?
  createdAt        DateTime   @default(now())
  logo             String?
  updatedAt        DateTime   @default(now()) @updatedAt
  verifiedAt       DateTime?
  campaigns        Campaign[]
  user             User       @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Campaign {
  id            Int              @id @default(autoincrement())
  charityId     Int
  title         String           @db.VarChar(150)
  description   String           @db.Text
  targetAmount  Decimal          @db.Decimal(12, 2)
  currentAmount Decimal          @default(0.00) @db.Decimal(12, 2)
  status        CampaignStatus   @default(ACTIVE)
  startDate     DateTime
  endDate       DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  donorCount    Int              @default(0)
  imageUrl      String?
  charity       CharityProfile   @relation(fields: [charityId], references: [id], onDelete: Cascade)
  donations     Donation[]
  followers     FollowCampaign[]

  @@index([charityId], map: "Campaign_charityId_fkey")
}

model Donation {
  id            Int            @id @default(autoincrement())
  donorId       Int
  campaignId    Int
  amount        Decimal        @db.Decimal(12, 2)
  isAnonymous   Boolean        @default(false)
  message       String?        @db.Text
  transactionId String?
  status        DonationStatus @default(PENDING)
  donatedAt     DateTime       @default(now())
  campaign      Campaign       @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  donor         User           @relation(fields: [donorId], references: [id], onDelete: Cascade)

  @@index([campaignId], map: "Donation_campaignId_fkey")
  @@index([donorId], map: "Donation_donorId_fkey")
}

model FollowCampaign {
  id         Int      @id @default(autoincrement())
  userId     Int
  campaignId Int
  createdAt  DateTime @default(now())
  campaign   Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, campaignId])
  @@index([campaignId], map: "FollowCampaign_campaignId_fkey")
}

model BankAccount {
  id            Int             @id @default(autoincrement())
  userId        Int
  bankName      String
  accountNumber String
  accountHolder String
  type          BankAccountType @default(PERSONAL)
  isPrimary     Boolean         @default(false)
  createdAt     DateTime        @default(now())
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "BankAccount_userId_fkey")
}

enum Role {
  DONOR
  CHARITY
  ADMIN
}

enum CampaignStatus {
  ACTIVE
  CLOSED
  DRAFT
}

enum DonationStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
}

enum BankAccountType {
  PERSONAL
  BUSINESS
}
